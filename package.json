{
  "name": "requo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:app\" \"ngrok http 3000\"",
    "dev:app": "node --max-old-space-size=12288 ./node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "next start",
    "start:app": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "test:unit": "vitest run tests/unit/",
    "test:components": "vitest run tests/components/",
    "test:e2e": "npm run test:e2e:full",
    "test:e2e:smoke": "playwright test --grep \"@smoke\"",
    "test:e2e:full": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --conditions=react-server scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed-demo": "tsx --conditions=react-server scripts/seed-demo.ts",
    "test": "npm run test:unit && npm run test:components",
    "test:integration": "npm run db:migrate && vitest run tests/integration/ -c vitest.integration.config.ts",
    "test:all": "npm run test && npm run test:integration && npm run test:e2e",
    "test:coverage": "vitest run tests/unit/ tests/components/ --coverage"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.6",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.50.1",
    "@openrouter/sdk": "^0.10.2",
    "@opentelemetry/api": "^1.9.1",
    "@supabase/supabase-js": "^2.101.1",
    "@thesvg/react": "^2.1.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "country-to-currency": "^2.0.3",
    "currency-codes": "^2.2.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "groq-sdk": "^1.1.2",
    "i18n-iso-countries": "^7.14.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.3",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-markdown": "^10.1.0",
    "react-qr-code": "^2.0.18",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.10.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.2",
    "ngrok": "^5.0.0-beta.2",
    "pg": "^8.20.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
