# Environment - development, test, or production
NODE_ENV=development

# Database
# For local development: use localhost
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/quoteflow
# DATABASE_MIGRATION_URL=postgresql://postgres:postgres@127.0.0.1:5432/quoteflow

# For Supabase:
# DATABASE_URL uses pooler (6543) for app/runtime traffic
# DATABASE_MIGRATION_URL uses direct (5432) for Drizzle migrations
# Keep the host, username, password, and database the same. Only the port changes.
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-<region>.pooler.supabase.com:6543/postgres
DATABASE_DIRECT_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_MIGRATION_URL=postgresql://postgres.<project-ref>:<db-password>@aws-<region>.pooler.supabase.com:5432/postgres

# Better Auth
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace-with-a-random-secret-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000
# Optional explicit browser override. Same-origin setups can usually leave this unset.
NEXT_PUBLIC_BETTER_AUTH_URL=
# Optional dedicated HMAC secret for hashing opaque lookup tokens. Falls back to BETTER_AUTH_SECRET if unset.
APP_TOKEN_HASH_SECRET=
# Internal admin allowlist. Use normal Requo login, then manually visit /admin.
ADMIN_EMAILS=
# Admin console credentials (username/password login at admin.localhost:3000)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# Optional deployment host hint. Vercel usually provides this automatically.
VERCEL_URL=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional Search Console HTML tag verification (content value only).
GOOGLE_SITE_VERIFICATION=
# These credentials are also used for Google Calendar integration.
# If using Calendar, add calendar.events and calendar.readonly scopes in Google Cloud Console
# and add {BETTER_AUTH_URL}/api/google-calendar/callback as an authorized redirect URI.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-your-supabase-publishable-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key
# Required for dashboard notification realtime subscriptions when using Better Auth.
# In Supabase, this is the project JWT secret under Settings > API.
SUPABASE_JWT_SECRET=

# Web Push notifications (optional)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Email delivery
# Fallback order: Resend -> Mailtrap -> Brevo.
# All sending domains must be verified with each configured provider.
RESEND_API_KEY=
MAILTRAP_API_TOKEN=
BREVO_API_KEY=
EMAIL_DOMAIN=test.requo.app
EMAIL_FROM_DEFAULT="Requo Notifications <notifications@test.requo.app>"
EMAIL_FROM_NOTIFICATIONS="Requo Notifications <notifications@test.requo.app>"
EMAIL_FROM_SYSTEM="Requo System <system@test.requo.app>"
EMAIL_FROM_QUOTES="Requo Quotes <quotes@test.requo.app>"
EMAIL_FROM_SUPPORT="Requo Support <support@test.requo.app>"
# Legacy fallback. Prefer EMAIL_FROM_* values for new setup.
RESEND_FROM_EMAIL=
# RESEND_REPLY_TO_EMAIL can be your normal inbox where replies should land.
RESEND_REPLY_TO_EMAIL=support@test.requo.app

# AI Providers (fallback order: Groq → Cerebras → Gemini)
# Configure at least one. The router tries each configured provider in order,
# with multiple model fallbacks per provider. See lib/ai/config.ts for model lists.
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=

# Polar (https://docs.polar.sh)
# Create products in the Polar dashboard, copy their product IDs below, and
# configure a webhook endpoint pointing to {NEXT_PUBLIC_APP_URL}/api/billing/polar/webhook.
# POLAR_SERVER must be "sandbox" (default) for the sandbox dashboard or
# "production" for live charges.
#
# Sandbox first: develop and validate end-to-end against the sandbox
# dashboard. Cut over to production only after the sandbox flow has been
# verified — see docs/setup/billing.md (Production cutover) for the full
# checklist (creating production products, the production webhook
# endpoint, the production access token, env replacement order, and
# post-deploy verification).
#
# `POLAR_ACCESS_TOKEN` and `POLAR_WEBHOOK_SECRET` must come from the same
# dashboard as `POLAR_SERVER` — mixing sandbox tokens with
# `POLAR_SERVER=production` (or vice versa) silently fails at request
# time. Subscribe the webhook to:
#   subscription.created, subscription.active, subscription.updated,
#   subscription.canceled, subscription.uncanceled, subscription.revoked,
#   order.paid, order.updated, order.refunded
# Refunds happen in the Polar customer portal and reach Requo via
# subscription.canceled / subscription.revoked events; refund.* event
# subscriptions are not required.
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=sandbox
POLAR_PRO_PRODUCT_ID=
POLAR_BUSINESS_PRODUCT_ID=
POLAR_PRO_YEARLY_PRODUCT_ID=
POLAR_BUSINESS_YEARLY_PRODUCT_ID=
# Public app origin used to build Polar hosted checkout success/cancel URLs.
# Example: http://localhost:3000 in dev, https://requo.app in production.
NEXT_PUBLIC_APP_URL=

# Optional demo seed overrides
DEMO_OWNER_NAME=Morgan Lee
DEMO_OWNER_EMAIL=demo@requo.local
DEMO_OWNER_PASSWORD=ChangeMe123456!
DEMO_BUSINESS_NAME=BrightSide Print Studio
DEMO_BUSINESS_SLUG=brightside-print-studio
# Optional test/demo URL token overrides used by the demo seed and Playwright fixtures.
DEMO_QUOTE_PUBLIC_TOKEN=demoquote1002senttoken
DEMO_EXPIRED_QUOTE_PUBLIC_TOKEN=demoquote1005expiredtoken
DEMO_VOIDED_QUOTE_PUBLIC_TOKEN=demoquote1006voidedtoken
